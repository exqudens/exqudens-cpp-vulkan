{
    "version": 3,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 25
    },
    "configurePresets": [
        {
            "name": "default",
            "hidden": true,
            "cacheVariables": {
                "PRESET_NAME": {
                    "type": "STRING",
                    "value": "${presetName}"
                }
            }
        },

        {
            "name": "windows",
            "hidden": true,
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },
        {
            "name": "linux",
            "hidden": true,
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            }
        },
        {
            "name": "darwin",
            "hidden": true,
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            }
        },

        {
            "name": "ninja",
            "hidden": true,
            "generator": "Ninja"
        },

        {
            "name": "msvc-x64-x64",
            "hidden": true,
            "toolset": {
                "strategy": "external",
                "value": "x64"
            },
            "architecture": {
                "strategy": "external",
                "value": "x64"
            },
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": {
                    "type": "FILEPATH",
                    "value": "build/msvc-x64-x64-toolchain.cmake"
                }
            }
        },
        {
            "name": "gcc",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": {
                    "type": "FILEPATH",
                    "value": "build/gcc-toolchain.cmake"
                },
                "CONAN_COMPILER_LIBCXX": {
                    "type": "STRING",
                    "value": "libstdc++11"
                }
            }
        },
        {
            "name": "clang",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": {
                    "type": "FILEPATH",
                    "value": "build/clang-toolchain.cmake"
                }
            }
        },

        {
            "name": "interface",
            "hidden": true,
            "cacheVariables": {
                "HEADER_ONLY": {
                    "type": "BOOL",
                    "value": true
                }
            }
        },
        {
            "name": "static",
            "hidden": true,
            "cacheVariables": {
                "BUILD_SHARED_LIBS": {
                    "type": "BOOL",
                    "value": false
                }
            }
        },
        {
            "name": "shared",
            "hidden": true,
            "cacheVariables": {
                "BUILD_SHARED_LIBS": {
                    "type": "BOOL",
                    "value": true
                }
            }
        },

        {
            "name": "debug",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": {
                    "type": "STRING",
                    "value": "Debug"
                }
            }
        },
        {
            "name": "release",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": {
                    "type": "STRING",
                    "value": "Release"
                }
            }
        },

        {
            "name": "mtd",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_MSVC_RUNTIME_LIBRARY": {
                    "type": "STRING",
                    "value": "MultiThreadedDebug"
                }
            }
        },
        {
            "name": "mdd",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_MSVC_RUNTIME_LIBRARY": {
                    "type": "STRING",
                    "value": "MultiThreadedDebugDLL"
                }
            }
        },
        {
            "name": "mt",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_MSVC_RUNTIME_LIBRARY": {
                    "type": "STRING",
                    "value": "MultiThreaded"
                }
            }
        },
        {
            "name": "md",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_MSVC_RUNTIME_LIBRARY": {
                    "type": "STRING",
                    "value": "MultiThreadedDLL"
                }
            }
        },

        {
            "name": "windows.ninja.msvc-x64-x64.interface",
            "inherits": ["default", "windows", "ninja", "msvc-x64-x64", "interface", "debug", "static", "mtd"],
            "binaryDir": "${sourceDir}/build/000"
        },
        {
            "name": "windows.ninja.msvc-x64-x64.debug.static",
            "hidden": true,
            "inherits": ["default", "windows", "ninja", "msvc-x64-x64", "debug", "static", "mtd"],
            "binaryDir": "${sourceDir}/build/001"
        },
        {
            "name": "windows.ninja.msvc-x64-x64.release.static",
            "hidden": true,
            "inherits": ["default", "windows", "ninja", "msvc-x64-x64", "release", "static", "mt"],
            "binaryDir": "${sourceDir}/build/002"
        },
        {
            "name": "windows.ninja.msvc-x64-x64.debug.shared",
            "hidden": true,
            "inherits": ["default", "windows", "ninja", "msvc-x64-x64", "debug", "shared", "mdd"],
            "binaryDir": "${sourceDir}/build/003"
        },
        {
            "name": "windows.ninja.msvc-x64-x64.release.shared",
            "hidden": true,
            "inherits": ["default", "windows", "ninja", "msvc-x64-x64", "release", "shared", "md"],
            "binaryDir": "${sourceDir}/build/004"
        },

        {
            "name": "linux.ninja.gcc.interface",
            "inherits": ["default", "linux", "ninja", "gcc", "interface", "debug", "static"],
            "binaryDir": "${sourceDir}/build/100"
        },
        {
            "name": "linux.ninja.gcc.debug.static",
            "hidden": true,
            "inherits": ["default", "linux", "ninja", "gcc", "debug", "static"],
            "binaryDir": "${sourceDir}/build/101"
        },
        {
            "name": "linux.ninja.gcc.release.static",
            "hidden": true,
            "inherits": ["default", "linux", "ninja", "gcc", "release", "static"],
            "binaryDir": "${sourceDir}/build/102"
        },
        {
            "name": "linux.ninja.gcc.debug.shared",
            "hidden": true,
            "inherits": ["default", "linux", "ninja", "gcc", "debug", "shared"],
            "binaryDir": "${sourceDir}/build/103"
        },
        {
            "name": "linux.ninja.gcc.release.shared",
            "hidden": true,
            "inherits": ["default", "linux", "ninja", "gcc", "release", "shared"],
            "binaryDir": "${sourceDir}/build/104"
        },

        {
            "name": "darwin.ninja.clang.interface",
            "inherits": ["default", "darwin", "ninja", "clang", "interface", "debug", "static"],
            "binaryDir": "${sourceDir}/build/200"
        },
        {
            "name": "darwin.ninja.clang.debug.static",
            "hidden": true,
            "inherits": ["default", "darwin", "ninja", "clang", "debug", "static"],
            "binaryDir": "${sourceDir}/build/201"
        },
        {
            "name": "darwin.ninja.clang.release.static",
            "hidden": true,
            "inherits": ["default", "darwin", "ninja", "clang", "release", "static"],
            "binaryDir": "${sourceDir}/build/202"
        },
        {
            "name": "darwin.ninja.clang.debug.shared",
            "hidden": true,
            "inherits": ["default", "darwin", "ninja", "clang", "debug", "shared"],
            "binaryDir": "${sourceDir}/build/203"
        },
        {
            "name": "darwin.ninja.clang.release.shared",
            "hidden": true,
            "inherits": ["default", "darwin", "ninja", "clang", "release", "shared"],
            "binaryDir": "${sourceDir}/build/204"
        }
    ],
    "buildPresets": [
        {
            "name": "default",
            "hidden": true,
            "jobs": 4
        },

        {
            "name": "windows.ninja.msvc-x64-x64.interface",
            "configurePreset": "windows.ninja.msvc-x64-x64.interface",
            "inherits": ["default"]
