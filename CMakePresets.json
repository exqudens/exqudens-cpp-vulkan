        },

        {
            "name": "darwin.ninja.clang.interface",
            "configurePreset": "darwin.ninja.clang.interface",
            "inherits": ["default"]
        },
        {
            "name": "darwin.ninja.clang.debug.static",
            "configurePreset": "darwin.ninja.clang.debug.static",
