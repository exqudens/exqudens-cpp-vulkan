        },
        {
            "name": "linux.ninja.gcc.release.static",
            "configurePreset": "linux.ninja.gcc.release.static",
            "inherits": ["default"]
        },
        {
            "name": "linux.ninja.gcc.debug.shared",
            "configurePreset": "linux.ninja.gcc.debug.shared",
